        margin-bottom: 10px;
    }

    .ts-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .ts-input {
        border-radius: 10px;
        border: 1px solid #e0e0e0;
        background: #fafafa;
        padding: 10px 12px;
    }

    .ts-input:focus {
        border-color: #b98af0;
        box-shadow: 0 0 0 0.2rem rgba(109, 40, 217, 0.15);
        background: #fff;
    }

    .ts-approver-box {
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        padding: 6px;
        background: #fafafa;
    }

    .ts-approver-option {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 8px;
        cursor: pointer;
        border: 1px solid transparent;
        margin: 0;
    }

    .ts-approver-option + .ts-approver-option {
        margin-top: 2px;
    }

    .ts-approver-option:hover {
        background: #f0eafb;
    }

    .ts-approver-option.selected {
        background: #f5eefc;
        border-color: #d9c2f2;
    }

    .ts-approver-option input[type="radio"] {
        accent-color: #6d28d9;
        width: 18px;
        height: 18px;
        flex: 0 0 auto;
    }

    .ts-approver-option span {
        display: flex;
        flex-direction: column;
        line-height: 1.3;
    }

    .ts-approver-option strong {
        font-size: 0.92rem;
        color: #222;
    }

    .ts-approver-option small {
        color: #888;
        font-size: 0.78rem;
    }

    .ts-generate-btn {
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: none;
        border-radius: 999px;
        padding: 14px;
        font-weight: 700;
        font-size: 1rem;
        color: #fff;
        background: linear-gradient(135deg, #6d28d9, #ec4899);
        box-shadow: 0 10px 25px rgba(109, 40, 217, 0.35);
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .ts-btn-icon {
        flex: 0 0 auto;
    }

    .ts-generate-btn:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 14px 30px rgba(109, 40, 217, 0.4);
    }

    .ts-generate-btn:disabled {
        opacity: 0.7;
    }

    @@media (min-width: 900px) {
        .ts-actions {
            display: flex;
            justify-content: center;
        }

        .ts-generate-btn {
            width: auto;
            min-width: 340px;
        }
    }

    .ts-footer {
        text-align: center;
        margin: 20px 0 0;
        font-size: 0.72rem;
        color: #aaa;
    }

    .legend-dot {
        display: inline-block;
        width: 14px;
        height: 14px;
        border-radius: 3px;
        margin-right: 4px;
        vertical-align: middle;
    }
</style>

@code {
    private int Year { get; set; } = DateTime.Now.Year;
    private int Month { get; set; } = DateTime.Now.Month;
    private string EmployeeName { get; set; } = "";
    private string EmployeeRole { get; set; } = "";
    private int SelectedApproverIndex { get; set; } = 1;
    private bool IsProcessing { get; set; }
    private string ErrorMessage { get; set; } = "";
    private string SuccessMessage { get; set; } = "";

    private List<DayEntry> DayEntries { get; set; } = new();

    protected override void OnInitialized() => RebuildDays();

    private void RebuildDays()
    {
        var days = DateTime.DaysInMonth(Year, Month);
        var existing = DayEntries.ToDictionary(d => d.Date);

        DayEntries = Enumerable.Range(1, days)
            .Select(d =>
            {
                var date = new DateOnly(Year, Month, d);
                var kind = existing.TryGetValue(date, out var prev)
                    ? prev.Kind
                    : IsWeekend(date) ? DateKind.Weekend : DateKind.None;
                return new DayEntry(date, kind);
            })
            .ToList();
    }

    private static bool IsWeekend(DateOnly d) =>
        d.DayOfWeek == DayOfWeek.Friday || d.DayOfWeek == DayOfWeek.Saturday;

    private static string SanitizeFileNamePart(string value)
    {
        var trimmed = value.Trim();
        var invalid = Path.GetInvalidFileNameChars();
        return string.Concat(trimmed.Select(c => invalid.Contains(c) ? '_' : c));
    }

    private static string GetKindValue(DayEntry entry) => entry.Kind switch
    {
        DateKind.Weekend => "weekend",
        DateKind.Holiday => "holiday",
        DateKind.Leave   => entry.LeaveKind == LeaveType.Casual ? "leave:casual" : "leave:annual",
        DateKind.Mission => "mission",
        _                => "none"
    };

    private void OnKindChanged(DayEntry entry, ChangeEventArgs e)
    {
        var parts = (e.Value?.ToString() ?? "none").Split(':');
        entry.Kind = parts[0] switch
        {
            "weekend" => DateKind.Weekend,
            "holiday" => DateKind.Holiday,
            "leave"   => DateKind.Leave,
            "mission" => DateKind.Mission,
            _         => DateKind.None
        };
        entry.LeaveKind = entry.Kind == DateKind.Leave
            ? (parts.Length > 1 && parts[1] == "casual" ? LeaveType.Casual : LeaveType.Annual)
            : null;
    }

    private static string GetRowColor(DateKind kind) => kind switch
    {
        DateKind.Weekend => "#FCE4D6",
        DateKind.Holiday => "#FFF2CC",
        DateKind.Leave   => "#DDEBF7",
        DateKind.Mission => "#E2EFDA",
        _                => "#ffffff"
    };

    private async Task GenerateTimesheet()
    {
        if (Year < 2000 || Year > 2100)
        {
            ErrorMessage = "Please enter a valid year (2000-2100).";
            return;
        }

        IsProcessing = true;
        ErrorMessage = "";
        SuccessMessage = "";

        try
        {
            string approverName = SelectedApproverIndex == 1
                ? "Salem Jaber Al-Marri"
                : "Shaikha Abdulrahman AlKhulaifi";
            string approverRole = SelectedApproverIndex == 1
                ? "Head of E-Portal Development"
                : "Digital Government Systems Expert";

            var customDates = DayEntries
                .Where(d => d.Kind != DateKind.None)
                .ToDictionary(d => d.Date, d => (d.Kind, d.LeaveKind));

            var bytes = await TimesheetService.GenerateTimesheetBytesAsync(
                Year, Month, EmployeeName, EmployeeRole, approverName, approverRole, customDates);

            var namePart = string.IsNullOrWhiteSpace(EmployeeName) ? "Timesheet" : SanitizeFileNamePart(EmployeeName);
            var monthName = CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Month);
            var fileName = $"{namePart}-{monthName}-{Year:0000}.xlsx";

            using var stream = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);

            SuccessMessage = "File downloaded successfully!";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            Console.WriteLine(ex);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    private class DayEntry(DateOnly date, DateKind kind)
    {
        public DateOnly Date { get; } = date;
        public DateKind Kind { get; set; } = kind;
        public LeaveType? LeaveKind { get; set; }
    }
}
