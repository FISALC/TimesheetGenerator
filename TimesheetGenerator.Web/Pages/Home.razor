@page "/"
@using Microsoft.JSInterop
@using TimesheetGenerator.Web
@using System.Globalization
@inject TimesheetService TimesheetService
@inject IJSRuntime JS

<PageTitle>Timesheet Generator</PageTitle>

<div class="ts-page">
    <div class="ts-card">
        <div class="ts-header">
            <div class="ts-logo">FS</div>
            <div>
                <h1 class="ts-title">Timesheet Generator</h1>
                <p class="ts-subtitle">Create professional timesheets in seconds</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <div class="alert alert-success">@SuccessMessage</div>
        }

        <div class="ts-form-grid">
            <section class="ts-section ts-panel">
                <h2 class="ts-section-title">Employee Details</h2>
                <div class="ts-grid-2">
                    <input class="form-control ts-input" placeholder="e.g., Mohammed Fisal" @bind="EmployeeName" />
                    <input class="form-control ts-input" placeholder="e.g., Software Developer" @bind="EmployeeRole" />
                </div>
            </section>

            <section class="ts-section ts-panel">
                <h2 class="ts-section-title">Period</h2>
                <div class="ts-grid-2">
                    <input type="number" class="form-control ts-input" @bind="Year" @bind:after="RebuildDays" min="2000" max="2100" />
                    <select class="form-select ts-input" @bind="Month" @bind:after="RebuildDays">
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
                        }
                    </select>
                </div>
            </section>

            <section class="ts-section ts-panel ts-span-2">
                <h2 class="ts-section-title">Approver</h2>
                <div class="ts-approver-box">
                    <label class="ts-approver-option @(SelectedApproverIndex == 1 ? "selected" : "")">
                        <input type="radio" name="approver" checked="@(SelectedApproverIndex == 1)"
                               @onchange="@(() => SelectedApproverIndex = 1)" />
                        <span>
                            <strong>Salem Jaber Al-Marri</strong>
                            <small>Head of E-Portal Development</small>
                        </span>
                    </label>
                    <label class="ts-approver-option @(SelectedApproverIndex == 2 ? "selected" : "")">
                        <input type="radio" name="approver" checked="@(SelectedApproverIndex == 2)"
                               @onchange="@(() => SelectedApproverIndex = 2)" />
                        <span>
                            <strong>Shaikha Abdulrahman AlKhulaifi</strong>
                            <small>Digital Government Systems Expert</small>
                        </span>
                    </label>
                </div>
            </section>
        </div>

        <details class="ts-section ts-advanced">
            <summary class="ts-section-title">Advanced: Update Leave, Holiday &amp; Day Types</summary>
            <p class="ts-hint">Click any day below to mark it as Weekend, Public Holiday, Annual Leave, Casual Leave, or Mission.</p>

            <div class="legend-row d-flex flex-wrap gap-3 mb-2 small">
                <span><span class="legend-dot" style="background:#FCE4D6;"></span> Weekend</span>
                <span><span class="legend-dot" style="background:#FFF2CC;"></span> Public Holiday</span>
                <span><span class="legend-dot" style="background:#DDEBF7;"></span> Leave (Annual / Casual)</span>
                <span><span class="legend-dot" style="background:#E2EFDA;"></span> Mission</span>
                <span><span class="legend-dot" style="background:#ffffff; border:1px solid #ccc;"></span> Work Day</span>
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-bordered mb-0" style="font-size:0.85rem;">
                    <thead>
                        <tr class="text-center" style="background:#404040; color:white;">
                            <th>Day</th>
                            <th>Date</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in DayEntries)
                        {
                            <tr style="background-color:@GetRowColor(entry.Kind);">
                                <td class="text-center">@entry.Date.ToString("ddd")</td>
                                <td class="text-center">@entry.Date.ToString("d MMM")</td>
                                <td>
                                    <select class="form-select form-select-sm"
                                            value="@GetKindValue(entry)"
                                            @onchange="e => OnKindChanged(entry, e)">
                                        <option value="none">Work Day</option>
                                        <option value="weekend">Weekend</option>
                                        <option value="holiday">Public Holiday</option>
                                        <option value="leave:annual">Annual Leave</option>
                                        <option value="leave:casual">Casual Leave</option>
                                        <option value="mission">Mission</option>
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>

        <div class="ts-actions">
            <button class="ts-generate-btn" @onclick="GenerateTimesheet" disabled="@IsProcessing">
                @if (IsProcessing)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span> Generating...</span>
                }
                else
                {
                    <svg class="ts-btn-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="16" y1="13" x2="8" y2="13" />
                        <line x1="16" y1="17" x2="8" y2="17" />
                        <polyline points="10 9 9 9 8 9" />
                    </svg>
                    <span>Generate Timesheet</span>
                }
            </button>
        </div>

        <p class="ts-footer">&copy; @DateTime.Now.Year &nbsp;FISAL Software&nbsp; &bull; &nbsp;Developed by Mohammed Fisal</p>
    </div>
</div>

<style>
    .ts-page {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 56px 16px;
        background: linear-gradient(160deg, #f9f9fb 0%, #eceef4 100%);
        overflow: hidden;
    }

    .ts-page::before,
    .ts-page::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
        opacity: 0.25;
        z-index: 0;
        pointer-events: none;
    }

    .ts-page::before {
        width: 480px;
        height: 480px;
        top: -160px;
        left: -160px;
        background: #6d28d9;
    }

    .ts-page::after {
        width: 420px;
        height: 420px;
        bottom: -140px;
        right: -140px;
        background: #ec4899;
    }

    .ts-card {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 520px;
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 20px 45px rgba(31, 20, 70, 0.12);
        padding: 32px 28px;
        transition: max-width 0.2s ease;
    }

    @@media (min-width: 900px) {
        .ts-card {
            max-width: 880px;
            padding: 44px 52px;
        }
    }

    @@media (min-width: 1200px) {
        .ts-card {
            max-width: 1000px;
        }
    }

    .ts-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
    }

    .ts-logo {
        flex: 0 0 auto;
        width: 52px;
        height: 52px;
        border-radius: 14px;
        background: linear-gradient(135deg, #6d28d9, #ec4899);
        color: #fff;
        font-weight: 800;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 18px rgba(109, 40, 217, 0.35);
    }

    .ts-title {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, #6d28d9, #ec4899);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    @@media (min-width: 900px) {
        .ts-title {
            font-size: 1.9rem;
        }
    }

    .ts-subtitle {
        margin: 2px 0 0;
        font-size: 0.85rem;
        color: #777;
    }

    .ts-form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 22px;
        margin-bottom: 22px;
    }

    @@media (min-width: 900px) {
        .ts-form-grid {
            grid-template-columns: 1fr 1fr;
            column-gap: 24px;
        }

        .ts-form-grid .ts-span-2 {
            grid-column: 1 / -1;
        }
    }

    .ts-panel {
        background: #fbfaff;
        border: 1px solid #ece7f7;
        border-radius: 14px;
        padding: 18px 18px 20px;
    }

    .ts-section {
        margin-bottom: 22px;
    }

    .ts-form-grid .ts-section {
        margin-bottom: 0;
    }

    .ts-section-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
        cursor: default;
    }

    details.ts-advanced {
        border: 1px solid #ece7f7;
        border-radius: 12px;
        background: #fbfaff;
        overflow: hidden;
    }

    details.ts-advanced summary.ts-section-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 14px 16px;
        margin-bottom: 0;
        cursor: pointer;
        user-select: none;
        list-style: none;
        transition: background 0.15s ease;
    }

    details.ts-advanced summary.ts-section-title:hover {
        background: #f0eafb;
    }

    details.ts-advanced summary.ts-section-title::-webkit-details-marker {
        display: none;
    }

    details.ts-advanced summary.ts-section-title::after {
        content: '';
        flex: 0 0 auto;
        width: 8px;
        height: 8px;
        margin-top: -2px;
        border-right: 2px solid #ec4899;
        border-bottom: 2px solid #ec4899;
        transform: rotate(45deg);
        transition: transform 0.2s ease;
    }

    details.ts-advanced[open] summary.ts-section-title::after {
        transform: rotate(-135deg);
        margin-top: 2px;
    }

    details.ts-advanced .ts-hint,
    details.ts-advanced .legend-row,
    details.ts-advanced .table-responsive {
