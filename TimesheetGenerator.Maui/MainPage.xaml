<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TimesheetGenerator.Maui.MainPage">

    <ContentPage.Resources>
        <!-- Colors -->
        <Color x:Key="PrimaryColor">#963634</Color>
        <Color x:Key="PrimaryDarkColor">#7a2b2a</Color>
        <Color x:Key="SecondaryColor">#f5f5f5</Color>
        <Color x:Key="CardBackground">#FFFFFF</Color>

        <!-- Styles -->
        <Style x:Key="CardFrame" TargetType="Frame">
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="HasShadow" Value="True" />
            <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BorderColor" Value="Transparent" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="#666666" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>

        <Style x:Key="InputLabel" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextColor" Value="#333333" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="CornerRadius" Value="25" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HeightRequest" Value="50" />
            <Setter Property="Shadow">
                <Shadow Brush="Black" Offset="0,4" Radius="5" Opacity="0.2" />
            </Setter>
        </Style>
    </ContentPage.Resources>

    <!-- Main Background Gradient -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F9F9F9" Offset="0.0" />
            <GradientStop Color="#E6E6E6" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20,40,20,20" Spacing="25" MaximumWidthRequest="600" HorizontalOptions="Center">

            <!-- Logo & Title -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,0,0,10">
                <Image Source="logo.png" 
                       WidthRequest="120" 
                       HeightRequest="120" 
                       Aspect="AspectFit">
                    <Image.Shadow>
                        <Shadow Brush="{StaticResource PrimaryColor}" Offset="0,5" Radius="10" Opacity="0.3"/>
                    </Image.Shadow>
                </Image>
                
                <Label Text="TIMESHEET" 
                       FontSize="28" 
                       FontAttributes="Bold" 
                       TextColor="{StaticResource PrimaryColor}" 
                       HorizontalOptions="Center"
                       CharacterSpacing="2"/>
                <Label Text="GENERATOR" 
                       FontSize="16" 
                       TextColor="#555" 
                       HorizontalOptions="Center"
                       CharacterSpacing="4"
                       Margin="0,-5,0,0"/>
            </VerticalStackLayout>

            <!-- Card: Period Selection -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout>
                    <Label Text="Period Selection" Style="{StaticResource SectionTitle}" />

                    <FlexLayout Wrap="Wrap" JustifyContent="SpaceBetween" AlignItems="Stretch" Direction="Row">
                        
                        <!-- Year Input -->
                        <VerticalStackLayout FlexLayout.Basis="48%" FlexLayout.Grow="1" Spacing="5" Margin="0,0,5,10" MinimumWidthRequest="250">
                            <Label Text="Year" Style="{StaticResource InputLabel}" />
                            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8" BackgroundColor="#FAFAFA" HeightRequest="55" VerticalOptions="Fill">
                                <Entry x:Name="EntYear" Text="2025" Keyboard="Numeric" TextColor="#333" FontAttributes="Bold" Placeholder="2025" BackgroundColor="Transparent" VerticalOptions="Center" VerticalTextAlignment="Center" Margin="10,0" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Month Input -->
                        <VerticalStackLayout FlexLayout.Basis="48%" FlexLayout.Grow="1" Spacing="5" Margin="5,0,0,10" MinimumWidthRequest="250">
                            <Label Text="Month" Style="{StaticResource InputLabel}" />
                            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8" BackgroundColor="#FAFAFA" HeightRequest="55" VerticalOptions="Fill">
                                <Picker x:Name="PckMonth" TextColor="#333" FontAttributes="Bold" BackgroundColor="Transparent" VerticalOptions="Center" Margin="10,0">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>1 - January</x:String>
                                            <x:String>2 - February</x:String>
                                            <x:String>3 - March</x:String>
                                            <x:String>4 - April</x:String>
                                            <x:String>5 - May</x:String>
                                            <x:String>6 - June</x:String>
                                            <x:String>7 - July</x:String>
                                            <x:String>8 - August</x:String>
                                            <x:String>9 - September</x:String>
                                            <x:String>10 - October</x:String>
                                            <x:String>11 - November</x:String>
                                            <x:String>12 - December</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </Border>
                        </VerticalStackLayout>
                    </FlexLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Card: Approver Selection -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Approver Selection" Style="{StaticResource SectionTitle}" />

                    <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10" BackgroundColor="#FAFAFA">
                        <VerticalStackLayout Spacing="5">
                            <RadioButton x:Name="RbApprover1" Content="Salem Jaber Al-Marri (Head of E-Portal Development)" IsChecked="True" TextColor="#333" />
                            <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,5"/>
                            <RadioButton x:Name="RbApprover2" Content="Shaikha Abdulrahman AlKhulaifi (Digital Government Systems Expert)" TextColor="#333" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Frame>

            <!-- Action Button -->
            <Button Text="Generate Timesheet" 
                    Clicked="OnGenerateClicked"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,10,0,0"/>

            <!-- Status -->
            <VerticalStackLayout Spacing="5">
                <Label x:Name="LblStatus" Text="Ready to generate" TextColor="#888" FontSize="12" HorizontalOptions="Center" FontAttributes="Italic"/>
                <Label Text="© 2025 Moahmmed Fisal" TextColor="#AAA" FontSize="10" HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
